# Root-level env example (individual .env files live in /client and /server)
# Copy this to .env and fill in values, OR configure /client/.env and /server/.env directly.

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/curtains_erp?sslmode=require"

# JWT
JWT_SECRET=change_me_to_a_long_random_string_minimum_64_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=another_long_random_string_minimum_64_chars
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS origin (frontend URL)
CLIENT_URL=http://localhost:5173

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Exchange rate auto-fetch (optional)
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key_here
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6

# ── Client ───────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000/api
